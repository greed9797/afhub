{
  "name": "vbo-ai",
  "description": "Nova alternativa ao Higgsfield AI — estúdio de imagem, vídeo, cinema e lip sync com IA. VBO é a nova IA com Agentes de IA e Fluxos de Trabalho Automáticos. Conecte sua chave de API e aproveite o melhor criador de vídeo com Agentes do mundo.",
  "private": true,
  "version": "1.0.1",
  "workspaces": [
    "packages/studio",
    "affiliate-engine"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "node --test tests/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "build:studio": "npm run build -w studio",
    "affiliate:dev": "npm run dev -w affiliate-engine",
    "affiliate:build": "npm run build -w affiliate-engine",
    "affiliate:test": "npm run test -w affiliate-engine",
    "affiliate:start": "npm run start -w affiliate-engine",
    "affiliate:worker:affiliate": "npm run worker:affiliate -w affiliate-engine",
    "affiliate:worker:video": "npm run worker:video -w affiliate-engine",
    "affiliate:worker:publisher": "npm run worker:publisher -w affiliate-engine",
    "local:infra": "docker compose -f docker-compose.dev.yml up -d",
    "local:infra:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "local:down": "docker compose -f docker-compose.dev.yml down",
    "local:reset": "docker compose -f docker-compose.dev.yml down -v",
    "local:migrate": "bash scripts/local-supabase-migrate.sh",
    "build:packages": "npm run build:studio",
    "setup": "npm install && npm run build:packages",
    "vite:dev": "vite",
    "vite:build": "vite build",
    "electron:dev": "npm run vite:build && electron .",
    "electron:build": "vite build && electron-builder --mac",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:linux": "vite build && electron-builder --linux",
    "electron:build:all": "vite build && electron-builder --mac --win --linux"
  },
  "build": {
    "appId": "ai.vbo.agent",
    "productName": "VBO.AI",
    "copyright": "Copyright © 2025",
    "directories": {
      "output": "release"
    },
    "afterPack": "./afterPack.js",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "public/banner.png",
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "public/banner.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    },
    "linux": {
      "icon": "public/banner.png",
      "category": "Utility",
      "maintainer": "VBO.AI Team",
      "extraFiles": [
        {
          "from": "build/linux/apparmor.profile",
          "to": "resources/apparmor.profile"
        }
      ],
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "archiver": "^7.0.1",
    "axios": "^1.7.0",
    "framer-motion": "^12.38.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.4.1",
    "sharp": "^0.34.5",
    "studio": "*"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.18",
    "autoprefixer": "^10.4.24",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.0"
  },
  "main": "electron/main.js"
}
